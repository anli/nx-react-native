{
  "name": "nx-react-native",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "android": "nx run-android",
    "build": "nx build",
    "ios": "nx run-ios",
    "lint": "nx affected:lint",
    "pod-install": "nx affected --target=pod-install",
    "start": "nx serve",
    "test": "nx affected:test",
    "test-coverage": "rm -rf coverage && npx nx run-many --all --target=test --configuration=coverage --skip-nx-cache && node tools/combine-coverage-final.js && nyc merge coverage coverage/combine-coverage/coverage.json && nyc report -t coverage/combine-coverage --report-dir coverage/combine-coverage --reporter=html --reporter=lcov",
    "type-check": "nx affected --target=type-check",
    "prepare": "husky install"
  },
  "private": true,
  "devDependencies": {
    "@nrwl/cli": "14.3.6",
    "@nrwl/detox": "14.3.6",
    "@nrwl/eslint-plugin-nx": "14.3.6",
    "@nrwl/jest": "14.3.6",
    "@nrwl/linter": "14.3.6",
    "@nrwl/react-native": "^14.3.6",
    "@nrwl/web": "14.3.6",
    "@nrwl/workspace": "14.3.6",
    "@react-native-async-storage/async-storage": "1.17.6",
    "@react-native-community/cli": "7.0.3",
    "@react-native-community/cli-platform-android": "7.0.1",
    "@react-native-community/cli-platform-ios": "7.0.1",
    "@testing-library/jest-dom": "5.16.4",
    "@testing-library/jest-native": "4.0.5",
    "@testing-library/react-native": "9.1.0",
    "@types/jest": "27.4.1",
    "@types/node": "16.11.7",
    "@types/react": "^17.0.47",
    "@types/react-native": "0.67.8",
    "@typescript-eslint/eslint-plugin": "^4.33.0",
    "@typescript-eslint/parser": "~5.24.0",
    "babel-jest": "27.5.1",
    "detox": "19.7.1",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "8.1.0",
    "eslint-config-standard-with-typescript": "^21.0.1",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "6.5.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.2.0",
    "eslint-plugin-react": "7.30.0",
    "eslint-plugin-react-hooks": "4.6.0",
    "husky": "^8.0.1",
    "jest": "27.5.1",
    "jest-circus": "27.5.1",
    "jest-react-native": "18.0.0",
    "metro": "0.71.1",
    "metro-babel-register": "0.71.1",
    "metro-react-native-babel-preset": "0.71.1",
    "metro-resolver": "0.71.1",
    "nx": "14.3.6",
    "nyc": "^15.1.0",
    "prettier": "^2.6.2",
    "react-native-config": "1.4.6",
    "react-native-svg": "12.3.0",
    "react-native-svg-transformer": "1.0.0",
    "react-test-renderer": "^17.0.2",
    "ts-jest": "27.1.4",
    "ts-node": "~10.8.0",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "@react-navigation/native": "^6.0.10",
    "@react-navigation/native-stack": "^6.6.2",
    "react": "^17.0.2",
    "react-native": "0.68.2",
